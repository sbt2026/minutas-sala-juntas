<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Encabezado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="53dp"
                android:src="@drawable/logo_blanco"
                android:contentDescription="Contexto Arquitectos"
                android:layout_marginEnd="20dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MINUTAS DE REUNIÓN"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:textColor="@color/text"/>

            <TextView
                android:id="@+id/txtFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="19sp"
                android:textColor="@color/text2"
                android:layout_marginEnd="24dp"/>

            <Button
                android:id="@+id/btnAjustes"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙ Ajustes"
                android:textSize="17sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Panel izquierdo -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginEnd="16dp">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <EditText
                            android:id="@+id/editProyecto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Proyecto (ej. Avenida Tecamachalco 35)"
                            android:textColorHint="@color/text2"
                            android:textColor="@color/text"
                            android:textSize="18sp"
                            android:inputType="textCapSentences"/>

                        <EditText
                            android:id="@+id/editCoordinador"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Coordinador"
                            android:textColorHint="@color/text2"
                            android:textColor="@color/text"
                            android:textSize="18sp"
                            android:inputType="textCapWords"/>

                        <EditText
                            android:id="@+id/editTema"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tema de la reunión"
                            android:textColorHint="@color/text2"
                            android:textColor="@color/text"
                            android:textSize="18sp"
                            android:inputType="textCapSentences"/>

                        <EditText
                            android:id="@+id/editLugar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Lugar de la reunión"
                            android:textColorHint="@color/text2"
                            android:textColor="@color/text"
                            android:textSize="18sp"
                            android:inputType="textCapSentences"/>

                        <EditText
                            android:id="@+id/editParticipantes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Participantes: Nombre (Empresa), Nombre (Empresa)"
                            android:textColorHint="@color/text2"
                            android:textColor="@color/text"
                            android:textSize="18sp"
                            android:inputType="textCapWords"/>

                        <TextView
                            android:id="@+id/txtTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:text="00:00:00"
                            android:textSize="42sp"
                            android:textStyle="bold"
                            android:textColor="@color/text"
                            android:fontFamily="monospace"
                            android:layout_marginTop="14dp"/>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnRec"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/btn_rec"
                            android:text="GRABAR"
                            android:textSize="21sp"
                            android:textStyle="bold"
                            android:textColor="@color/text"/>

                        <TextView
                            android:id="@+id/txtEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="10dp"
                            android:text="Listo para grabar"
                            android:textSize="18sp"
                            android:textColor="@color/text2"/>
                    </LinearLayout>
                </ScrollView>

                <Button
                    android:id="@+id/btnMinuta"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="10dp"
                    android:text="Generar minuta"
                    android:textSize="20sp"
                    android:enabled="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <Button
                        android:id="@+id/btnWord"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:layout_weight="1"
                        android:text="Word"
                        android:textSize="15sp"
                        android:enabled="false"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnPdf"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:layout_weight="1"
                        android:text="PDF"
                        android:textSize="15sp"
                        android:enabled="false"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnNueva"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                    android:layout_marginTop="10dp"
                    android:text="Nueva reunión"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Panel derecho -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transcripción en vivo"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text"
                    android:layout_marginBottom="8dp"/>

                <ScrollView
                    android:id="@+id/scrollTrans"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_transcript"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtTranscript"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="La transcripción aparecerá aquí…"
                        android:textSize="21sp"
                        android:textColor="@color/text"
                        android:lineSpacingExtra="6dp"/>
                </ScrollView>

                <TextView
                    android:id="@+id/lblMinuta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minuta"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <ScrollView
                    android:id="@+id/scrollMinuta"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_transcript"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtMinuta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="@color/text"
                        android:lineSpacingExtra="5dp"
                        android:textIsSelectable="true"/>
                </ScrollView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Portada -->
    <LinearLayout
        android:id="@+id/splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="380dp"
            android:layout_height="168dp"
            android:src="@drawable/logo_blanco"
            android:contentDescription="Contexto Arquitectos"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="MINUTAS DE REUNIÓN"
            android:textSize="26sp"
            android:letterSpacing="0.25"
            android:textColor="@color/text2"/>
    </LinearLayout>
</FrameLayout>
